{
  "name": "canadian-population-immigration-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "npm run validate:data && npm run typecheck && npm run build:app",
    "build:app": "vite build",
    "check": "npm run validate:data && npm run typecheck && npm run lint && npm run format:check && npm run test:coverage && npm run build:app",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "validate:data": "tsx scripts/validate-data.ts",
    "data:population": "tsx scripts/build-population-data.ts",
    "data:population-age": "tsx scripts/build-population-age-data.ts",
    "data:population-components": "tsx scripts/build-population-components.ts",
    "data:immigration": "tsx scripts/build-immigration-data.ts",
    "data:breakdowns": "tsx scripts/build-immigration-breakdowns.ts",
    "data:temporary": "tsx scripts/build-temporary-residents.ts",
    "data:economic": "tsx scripts/build-economic-context.ts",
    "data:all": "npm run data:population && npm run data:population-age && npm run data:population-components && npm run data:immigration && npm run data:breakdowns && npm run data:temporary && npm run data:economic && npm run validate:data"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "lucide-react": "^0.475.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@e965/xlsx": "^0.20.3",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.1",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.7",
    "autoprefixer": "^10.4.20",
    "csv-parse": "^6.2.1",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.1.1",
    "jszip": "^3.10.1",
    "postcss": "^8.5.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^6.1.0",
    "vitest": "^4.1.7"
  }
}
